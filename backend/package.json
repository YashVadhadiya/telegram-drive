{
  "name": "telegram-drive-backend",
  "version": "1.0.0",
  "description": "Telegram Drive Cloudflare Worker backend",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev --port 8787",
    "deploy": "wrangler deploy --env production",
    "deploy:dev": "wrangler deploy",
    "logs": "wrangler tail",
    "db:init": "wrangler d1 execute telegram-drive-db --file=src/database/schema.sql",
    "db:seed": "wrangler d1 execute telegram-drive-db --file=src/database/seed.sql",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "echo 'No TypeScript - JS project'"
  },
  "dependencies": {},
  "devDependencies": {
    "vitest": "^1.6.0",
    "wrangler": "^3.57.0"
  }
}
